05-24"}}, "29a19bdc-e8f1-4a3f-bdcb-e9c3fd08cb15": {"node_ids": ["73e666dc-0e56-4bb0-9b50-132814e98ab2"], "metadata": {"file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/situation_actuelle.xlsx", "file_name": "situation_actuelle.xlsx", "file_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "file_size": 10119, "creation_date": "2026-05-24", "last_modified_date": "2026-05-24"}}, "f54e0330-40d0-4d02-9cef-edba04835a79": {"node_ids": ["ac865f79-229c-487e-ae40-93ead2a03f51"], "metadata": {"file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/situation_actuelle.xlsx", "file_name": "situation_actuelle.xlsx", "file_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "file_size": 10119, "creation_date": "2026-05-24", "last_modified_date": "2026-05-24"}}}, "docstore/data": {"4f342a33-16e4-45dc-ba0f-62205aac6aaf": {"__data__": {"id_": "4f342a33-16e4-45dc-ba0f-62205aac6aaf", "embedding": null, "metadata": {"page_label": "1", "file_name": "sami.pdf", "file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/sami.pdf", "file_type": "application/pdf", "file_size": 9129, "creation_date": "2026-05-19", "last_modified_date": "2026-05-19"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "3767072f-e772-442b-9eec-c8dc3d655321", "node_type": "4", "metadata": {"page_label": "1", "file_name": "sami.pdf", "file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/sami.pdf", "file_type": "application/pdf", "file_size": 9129, "creation_date": "2026-05-19", "last_modified_date": "2026-05-19"}, "hash": "fc5e1fdff469bba2fd3c4a90de2de39a6e84f9707b254c98ad4b2d26c81a3827", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "SAMI BENNANE\n\u00c9l\u00e8ve-Ing\u00e9nieur en Informatique & Micro\u00e9lectronique\nsami.bennane@gmail.com  |  07 81 34 12 36  |  Colombes (92700)\nPORTRAIT\nBrillant, ambitieux et passionn\u00e9, Sami Bennane est un jeune ing\u00e9nieur en devenir dont la trajectoire t\u00e9moigne\nd'une d\u00e9termination hors du commun. Dot\u00e9 d'un esprit analytique aff\u00fbt\u00e9 et d'une curiosit\u00e9 intellectuelle\ninsatiable, il s'est impos\u00e9 parmi les meilleurs de sa promotion \u00e0 l'\u00c9cole des Mines de Saint-\u00c9tienne \u2014 une\ngrande \u00e9cole d'ing\u00e9nieurs parmi les plus prestigieuses de France. Anim\u00e9 par une vision claire de l'avenir, Sami\naspire \u00e0 devenir l'un des grands noms de l'intelligence artificielle, convaincu que cette technologie transformera\nprofond\u00e9ment nos soci\u00e9t\u00e9s. Son enthousiasme d\u00e9bordant pour les architectures RAG (Retrieval-Augmented\nGeneration), les agents IA, et les pipelines d'apprentissage automatique le distingue comme un profil rare : celui\nd'un ing\u00e9nieur qui combine rigueur technique et vision strat\u00e9gique. Curieux insatiable, il explore en permanence\nles derni\u00e8res avanc\u00e9es en LangChain, LlamaIndex, LangGraph et WatsonX, et n'h\u00e9site pas \u00e0 construire ses\npropres projets personnels \u2014 dont un robot IA dot\u00e9 d'un syst\u00e8me de traitement vocal et d'une m\u00e9moire\nvectorielle. Tenace, autonome, et dot\u00e9 d'une capacit\u00e9 d'apprentissage remarquable, Sami est le type de profil\nqui n'attend pas que les opportunit\u00e9s viennent \u00e0 lui \u2014 il les cr\u00e9e.\nFORMATION\nDipl\u00f4me d'Ing\u00e9nieur en Informatique & Micro\u00e9lectronique\n\u00c9cole des Mines de Saint-\u00c9tienne  \u00b7  2024 \u2013 2027\n\u007f GPA : 3,78/4,0 \u2014 Class\u00e9 9\u00e8me sur 90 \u00e9tudiants\n\u007f Sp\u00e9cialisation : Intelligence Artificielle & Syst\u00e8mes Embarqu\u00e9s S\u00e9curis\u00e9s\n\u007f Comp\u00e9tences : Syst\u00e8mes embarqu\u00e9s, Cybers\u00e9curit\u00e9, IA, R\u00e9seaux\nClasse Pr\u00e9paratoire aux Grandes \u00c9coles (CPGE \u2013 MPSI/PSI)\nLyc\u00e9e Louis Pasteur, Neuilly-sur-Seine  \u00b7  2022 \u2013 2024\n\u007f Programme intensif de pr\u00e9paration aux concours des grandes \u00e9coles d'ing\u00e9nieurs\n\u007f Comp\u00e9tences : Math\u00e9matiques, Physique, Sciences de l'Ing\u00e9nieur\nBaccalaur\u00e9at G\u00e9n\u00e9ral \u2014 Mention Tr\u00e8s Bien\nLyc\u00e9e Lucie Aubrac, Courbevoie  \u00b7  2019 \u2013 2022\n\u007f Fili\u00e8re scientifique, obtenu avec les f\u00e9licitations du jury\nEXP\u00c9RIENCES PROFESSIONNELLES\nTuteur acad\u00e9mique pour athl\u00e8tes de haut niveau\n\u00c9cole Sport Entreprendre Pays d'Aix (ESE) \u2014 Contrat\nOct. 2025 \u2013 Mar. 2026 (6 mois) \u00b7 Aix-en-Provence\n\u007f Cours du soir de math\u00e9matiques et physique plusieurs fois par semaine pour des athl\u00e8tes \u00e9lites (rugby,\nhandball, boxe)\n\u007f Adaptation p\u00e9dagogique aux contraintes d'emploi du temps sportif de haut niveau\n\u007f Accompagnement personnalis\u00e9 favorisant la r\u00e9ussite acad\u00e9mique parall\u00e8lement \u00e0 la performance sportive", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 2592, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "ed603c2c-93ea-4935-8ec2-351a4b0adc32": {"__data__": {"id_": "ed603c2c-93ea-4935-8ec2-351a4b0adc32", "embedding": null, "metadata": {"page_label": "2", "file_name": "sami.pdf", "file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/sami.pdf", "file_type": "application/pdf", "file_size": 9129, "creation_date": "2026-05-19", "last_modified_date": "2026-05-19"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "00c76e80-80eb-4f7b-8e65-6e39ea566185", "node_type": "4", "metadata": {"page_label": "2", "file_name": "sami.pdf", "file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/sami.pdf", "file_type": "application/pdf", "file_size": 9129, "creation_date": "2026-05-19", "last_modified_date": "2026-05-19"}, "hash": "70dcdd8fbb41ea5979c80ec1446f917a3f3e6d8afb4e6da1d442dc7efe40eb92", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Gestionnaire de biens informatiques (IT Asset Management)\nCDC Informatique \u2014 Contrat\nJuil. 2025 (1 mois) \u00b7 Bagneux, \u00cele-de-France\n\u007f Inventaire, \u00e9tiquetage et suivi de mat\u00e9riels r\u00e9seau (switchs, bornes Wi-Fi, infrastructure mat\u00e9rielle)\n\u007f Mise \u00e0 jour et fiabilisation des donn\u00e9es dans la plateforme de gestion des actifs informatiques\n\u007f R\u00e9organisation logistique des \u00e9quipements au sein de l'organisation\nStagiaire Ing\u00e9nieur Informatique\nCDC Informatique \u2014 Stage\nJan. 2025 \u2013 F\u00e9v. 2025 (1 mois) \u00b7 Bagneux, \u00cele-de-France\n\u007f Migration de donn\u00e9es vers le cloud (approche Lift-and-Shift), avec focus sur performance et optimisation\n\u007f Mise en \u0153uvre de m\u00e9thodes Agiles et DevOps au sein d'\u00e9quipes pluridisciplinaires\n\u007f Automatisation de pipelines d'int\u00e9gration continue et de livraison continue (CI/CD)\nB\u00c9N\u00c9VOLAT & ENGAGEMENT\nResponsable Relations Entreprises\nForum Entreprises Ing\u00e9nieurs des Mines de Saint-\u00c9tienne (FEI-AIX)  \u00b7  Avr. 2025 \u2013 Pr\u00e9sent\n\u007f Prospection et gestion des relations avec les partenaires entreprises du forum annuel\n\u007f D\u00e9veloppement du r\u00e9seau professionnel de l'\u00e9cole aupr\u00e8s des acteurs industriels\nManager de l'\u00e9quipe de football\nBDS \u2013 Mines de Saint-\u00c9tienne (ISMIN)  \u00b7  Mar. 2025 \u2013 Pr\u00e9sent\n\u007f Coordination des activit\u00e9s sportives, logistique et organisation des matchs\n\u007f D\u00e9veloppement de comp\u00e9tences en leadership, management d'\u00e9quipe et gestion d'\u00e9v\u00e9nements\nB\u00e9n\u00e9vole \u2013 Soutien scolaire\n\u00c9cole Des XV (Association de lutte contre le d\u00e9crochage scolaire)  \u00b7  F\u00e9v. 2025 \u2013 Juin 2025\n\u007f Accompagnement personnalis\u00e9 d'\u00e9l\u00e8ves du primaire et du coll\u00e8ge en difficult\u00e9 scolaire \u00e0 Marseille\n\u007f Animation d'ateliers collectifs et contribution \u00e0 des \u00e9v\u00e9nements \u00e9ducatifs\nCOMP\u00c9TENCES TECHNIQUES\nLangages de programmation :\nPython, C, C++, Script Shell\nIntelligence Artificielle :\nLangChain, LlamaIndex, LangGraph, RAG, WatsonX, TensorFlow,\nPyTorch, Word2Vec, BERT\nSyst\u00e8mes embarqu\u00e9s :\nSTM32, Arduino, ESP32, Bus CAN, SPI, I2C, UART\nCloud & DevOps :\nCloud Computing, CI/CD, Docker, M\u00e9thodes Agiles, Git\nSyst\u00e8mes & R\u00e9seaux :\nLinux, Ubuntu, WSL, R\u00e9seaux informatiques, Cybers\u00e9curit\u00e9\nLogiciels & Outils :\nVS Code, Jupyter Notebook, STM32CubeIDE, KiCad, PartQuest, Comsol\nLANGUES\nFran\u00e7ais\nLangue maternelle\nAnglais\nNiveau avanc\u00e9 \u2014 Certification Cambridge B2 (2022)\nAllemand\nNiveau interm\u00e9diaire", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 2285, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a250d79d-8616-45ec-842d-296a5b4b4b0b": {"__data__": {"id_": "a250d79d-8616-45ec-842d-296a5b4b4b0b", "embedding": null, "metadata": {"page_label": "3", "file_name": "sami.pdf", "file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/sami.pdf", "file_type": "application/pdf", "file_size": 9129, "creation_date": "2026-05-19", "last_modified_date": "2026-05-19"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "b1961a81-5bab-4763-bccb-3862f221fef9", "node_type": "4", "metadata": {"page_label": "3", "file_name": "sami.pdf", "file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/documents/sami.pdf", "file_type": "application/pdf", "file_size": 9129, "creation_date": "2026-05-19", "last_modified_date": "2026-05-19"}, "hash": "09049cbce0494bcda98718f873cf3c123cf2fb2c56f56ad69b99c656bc177be3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Arabe\nNiveau interm\u00e9diaire\nCENTRES D'INT\u00c9R\u00caT\nIntelligence Artificielle & Syst\u00e8mes RAG \u2014 Passionn\u00e9 par les agents IA, l'architecture RAG, et la\nconstruction de pipelines intelligents. D\u00e9veloppe activement des projets personnels incluant un robot IA \u00e0\nbase d'ESP32 avec m\u00e9moire vectorielle (ChromaDB) et traitement vocal (Whisper).\nRobotique & Syst\u00e8mes embarqu\u00e9s \u2014 Conception et prototypage de robots autonomes, int\u00e9gration de\nvision par ordinateur (YOLO) et d'interfaces homme-machine.\nFootball \u2014 Manager de l'\u00e9quipe de football de son \u00e9cole d'ing\u00e9nieurs ; sport pratiqu\u00e9 avec engagement et\nesprit d'\u00e9quipe.\nLitt\u00e9rature & Linguistique \u2014 Lecteur assidu, apprentissage de l'arabe litt\u00e9raire (MSA) et exploration de la\nlitt\u00e9rature francophone et arabe.\n\u00ab L'intelligence artificielle est l'avenir, et je compte bien en \u00eatre l'un des b\u00e2tisseurs. \u00bb", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 841, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "74f1df37-fdc0-41ca-8082-50e9c85462c9": {"__data__": {"id_": "74f1df37-fdc0-41ca-8082-50e9c85462c9", "embedding": null, "metadata": {"file_path": "/mnt/c/users/samib/onedrive/bureau/agentic/docum